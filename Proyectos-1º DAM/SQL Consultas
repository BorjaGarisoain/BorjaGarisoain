-- 1. Escribe una consulta que muestre todos los usuarios.
SELECT * 
FROM Usuarios;

-- 2. Escribe una consulta que muestre los títulos de las películas y la duración en horas.
SELECT titulo, TRUNC (duracion / 60) AS duracion_horas
FROM Peliculas;

-- 3. Muestra los géneros de películas únicos.
SELECT DISTINCT genero
FROM Peliculas;

-- 4. Obtén todas las películas ordenadas por su calificación en orden ascendente.
SELECT *
FROM Peliculas
ORDER BY calificacion;-- El orden ascendente es por defecto

-- 5. Obtén todos los géneros de películas únicos ordenados en orden descendente.
SELECT DISTINCT genero
FROM Peliculas
ORDER BY genero DESC;--El descendente hay que ponerlo porque no es por defecto

-- 6. Encuentra todas las películas cuyo título comienza con la letra 'T'.
SELECT *
FROM Peliculas
WHERE titulo LIKE 'T%';

-- 7. Encuentra todas las películas cuyo título tiene exactamente 10 caracteres.
SELECT *
FROM Peliculas
WHERE LENGTH (titulo) = 10;

-- 8. Encuentra las películas con duración mayor a 2 horas.
SELECT *
FROM Peliculas
WHERE duracion > 120;--La duracion está en minutos (por eso 120)

-- 9. Encuentra las películas con una calificación entre 8.0 y 9.0.
SELECT *
FROM Peliculas
WHERE calificacion >= 8.0 AND calificacion <= 9.0;--Utilizo un decimal porque en mi tabla Peliculas, la calificacion es un NUMBER (3,1)

-- 10. Encuentra las películas alquiladas realizadas después del 1 de noviembre de 2023.
SELECT *
FROM Alquilada
WHERE fecha_alquilada > DATE '2023-11-01';--Pongo la fecha en formato DATE para que oracle detecte que se trata de un DATE

-- 11. Muestra el precio de las películas alquiladas aumentado un 10% y el título de la película
SELECT Peliculas.titulo, Alquilada.precio*1.10 AS precio_nuevo
FROM Alquilada 
JOIN Peliculas ON alquilada.id_pelicula = peliculas.id_pelicula;--Esta línea es para declarar la foreign key (relación entre ambas tablas) porque necesito datos de ambas sobre la misma película (por eso usamos su ID)

-- 12. Muestra los nombres de los usuarios concatenados con su email.
SELECT nombre || ' ' || email --Utilizo el espacio del medio porque sino saldrían nombre y email segudos
FROM Usuarios;

-- 13. Encuentra las películas de género 'Drama' o con calificación mayor a 9.0.
SELECT *
FROM Peliculas
WHERE genero = 'Drama' OR calificacion > 9.0;

-- 14. Encuentra las películas alquiladas cuyo precio sea menor a 6 y fecha de devolución antes del 5 de noviembre de 2023.
SELECT *
FROM Alquilada
WHERE precio < 6 AND fecha_devolucion < DATE '2023-11-05';

-- 15. Muestra las películas con la duración redondeada al número entero más cercano.
SELECT titulo, ROUND (duracion)
FROM Peliculas;

-- 16. Muestra las películas con la duración truncada a la decena más cercana.
SELECT titulo, TRUNC(duracion, -1)--Utilizo -1 para que vaya a la parte entera , primera cifra, que corresponde a las decenas
FROM Peliculas;

-- 17. Muestra los nombres de los usuarios en mayúsculas.
SELECT UPPER (nombre)
FROM Usuarios;

-- 18. Muestra la cantidad de días entre la fecha de películas alquilada y la fecha de devolución.
SELECT id_alquilada, fecha_devolucion - fecha_alquilada AS dias_alquilados --Resto fecha2 - fecha1 para obtener el número de días alquilados
FROM Alquilada;

-- 19. Muestra el número total de películas alquiladas realizadas.
SELECT COUNT(*)
FROM Alquilada;

-- 20. Encuentra la calificación máxima de las películas.
SELECT MAX(calificacion)
FROM Peliculas;

-- 21. Muestra el número de películas por género.
SELECT genero, COUNT(*)
FROM Peliculas
GROUP BY genero;--Necesito usar GROUP BY porque el cálculo que se me pide es sobre un grupo de filas y no sobre una sola (necesito el número de películas de todos los genero)

-- 22. Muestra los géneros con más de 1 película.
SELECT genero 
FROM Peliculas
GROUP BY genero
HAVING COUNT(*) > 1;--Necesito usar el HAVING para filtrar los grupos (genero) que tienen más de 1

-- 23. Muestra las películas alquiladas junto con los nombres de los usuarios y los títulos de las películas.
SELECT Alquilada.id_alquilada,Usuarios.nombre,Peliculas.titulo
FROM Alquilada 
JOIN Usuarios ON Alquilada.id_usuario = Usuarios.id_usuario JOIN Peliculas ON Alquilada.id_pelicula = Peliculas.id_pelicula;--Es como la FOREIGN KEY del ejercicio 11 solo que eésta vez hay 2

-- 24. Muestra las películas alquiladas con los títulos de las películas usando LEFT JOIN.
SELECT Peliculas.titulo, Alquilada.id_alquilada
FROM Peliculas
LEFT JOIN Alquilada ON Peliculas.id_pelicula = Alquilada.id_alquilada;--Usando LEFT JOIN me aseguro que aparezcan todas las películas estén alquiladas o no

-- 25. Muestra los usuarios con sus alquiladas usando RIGHT JOIN
SELECT Usuarios.nombre, Alquilada.id_alquilada
FROM Alquilada
RIGHT JOIN Usuarios ON Alquilada.id_usuario = Usuarios.id_usuario; --Utilizando RIGHT JOIN me aseguro de que aparecen todos los Usuarios sin importar si han alquilado película o no

-- 26. Muestra los títulos de las películas y el número de veces que han sido alquiladas.
SELECT Peliculas.titulo, COUNT(Alquilada.id_alquilada) AS veces_alquilada
FROM Peliculas
LEFT JOIN Alquilada ON Peliculas.id_pelicula = Alquilada.id_alquilada--LEFT JOIN para mostrar todos los titulos de peliculas aunque no estén alquilados
GROUP BY Peliculas.titulo;

-- 27. Muestra los usuarios y sus gastos totales en películas alquiladas.
SELECT Usuarios.nombre, SUM (Alquilada.precio) AS gastos_totales--SUM suma todos los precios de alquilada
FROM Usuarios JOIN Alquilada ON Usuarios.id_usuario = Alquilada.id_usuario
GROUP BY Usuarios.nombre;

-- 28. Encuentra las películas alquiladas en noviembre de 2023.
SELECT Peliculas.titulo ,Alquilada.* 
FROM Alquilada
JOIN Peliculas ON Alquilada.id_pelicula = Peliculas.id_pelicula
WHERE fecha_alquilada >= DATE '2023-11-01' AND fecha_alquilada < DATE '2023-12-01';

-- 29. Encuentra los usuarios que han alquilado películas de más de 2 horas de duración.
SELECT DISTINCT Usuarios.nombre, Alquilada.id_alquilada, peliculas.id_pelicula,Peliculas.titulo, Peliculas.duracion--Utilizo DISTINCT porque un usuario puede alquilar varias películas
FROM Usuarios
JOIN Alquilada ON Usuarios.id_usuario = Alquilada.id_usuario
JOIN Peliculas ON Alquilada.id_pelicula = Peliculas.id_pelicula
WHERE Peliculas.duracion > 120;

-- 30. Encuentra las películas que tienen una calificación mayor que el promedio de todas las calificaciones.
SELECT *
FROM Peliculas
WHERE calificacion > (SELECT AVG (calificacion) FROM Peliculas);--Hago otro SELECT para la media utilizando AVG de la calificacion de películas y así poder compararla con calificacion para que me devuelva solo las que están por encima de la media

-- 31. Encuentra los géneros con calificación promedio mayor a 8.5 y el número total de películas en ese género.
SELECT genero, AVG(calificacion),COUNT (genero)--Selecciono genero, su media de calificacion y cuento el número total de pelúclas en el genero
FROM Peliculas
GROUP BY genero--Para agrupar las filas genero (quiero saber las calificaciones mayores de 8.5 "de cada" genero)
HAVING AVG(calificacion) > 8.5;--Pido que me devuelvan sólo los generos con una media mayor a 8.5

-- 32. Encuentra el usuario que más dinero ha gastado en películas alquiladas.
SELECT Usuarios.nombre, SUM (Alquilada.precio) AS mayor_gasto--Selecciono que quiero que la consulta me diga el nombre de usuario y la suma de sus gastos con el nombre que va detrás del AS
FROM Usuarios
JOIN Alquilada ON Usuarios.id_usuario = Alquilada.id_usuario--Es la declaración de la relación entre ambas tablas (foreign key)
GROUP BY Usuarios.nombre
HAVING SUM (Alquilada.precio) >= ALL--Comparo la subconsulta poniéndole la condición de que me devuelva el usuario cuyos gastos sean mayores o iguales a cada uno del resto de usuarios (de esta forma la comparación da el usuario que más ha gastado)
    (SELECT SUM (precio)--Esta es la subconsulta que proporciona un grupo de usuarios con la suma de sus gastos
    FROM Alquilada
    GROUP BY Alquilada.id_usuario);
    
-- 33. Encuentra las películas más largas en cada género.
SELECT titulo, genero, duracion
FROM Peliculas p1--Definimos p1 para diferenciar la tabla principal de la que vamos a usar para comprarar (aunque sean la misma)
WHERE duracion >=ALL--Obligamos a que nos devuelva la película que es mayor o igual al resto (la de mayor duracion). Similar al ejercicio anterior
    (SELECT duracion FROM peliculas p2 WHERE p2.genero = p1.genero);--Esta es la subconsulta en la que definimos la tabla comparativa p2 y le ponemos la condición de que nos devuelva sólo los valores que pertenezcan al mismo genero que el que se está analizando en p1. Es como un bucle (se lee el primer genero de p1, se llega a la frase de comparacion (p2.genero=p1.genero) y devuelve la mayor duracion del primer genero(frase >=ALL), se lee el segundo genero de p1...y así sucesivamente
--Me acabo de fijar que llevo toda la tarea escribiendo todos los nombres y podía haber utilizado alias

-- 34. Encuentra los usuarios que han alquilado más de una vez
SELECT Usuarios.nombre, COUNT (Alquilada.id_alquilada) AS total_alquileres--Pido que me muestre el nombre del cliente y que cuente el número de id de la tabla alquilada para obtener el número de veces que se ha alquilado (total de alquileres)
FROM Usuarios
JOIN Alquilada ON Usuarios.id_usuario = Alquilada.id_usuario--Establezco la conexión entre ambas tablas (foreign key)
GROUP BY Usuarios.nombre--Agrupo los nombres de usuarios para poder juntar los id_alquilada en un mismo sitio (cada nombre) y poder contarlos (Ej. Sandra (grupo) tiene 3 id_alquilada)
HAVING COUNT(Alquilada.id_alquilada) >1;--Pongo la condición de que los grupos de nombres deben tener más de 1 id_alquilada (deben haber alquilado más de una vez) 

-- 35. Encuentra la calificación promedio de las películas alquiladas por cada usuario.
SELECT u.nombre, AVG (calificacion) AS calificacion_promedio --Seleccionamos el nombre de usuario y aplicamos la media
FROM Usuarios u
JOIN Alquilada a ON u.id_usuario = a.id_usuario--Conectamos Usuarios con Alquilada para saber qué películas han alquilado los Usuarios
JOIN Peliculas p ON a.id_pelicula = p.id_pelicula--Conectamos con la tabla Peliculas porque es la que tiene la calificacion
GROUP BY u.nombre;--Agrupamos en nombre para que se calcule la media de las películas alquiladas de "cada usuario"

-- 36. Encuentra las películas alquiladas únicamente en las fechas que coinciden exactamente con la fecha de registro de algún usuario.
SELECT DISTINCT a.*--Utilizo DISTINCT para asegurar que cada alquiler aparezca una sola vez
FROM Alquilada a
JOIN Usuarios u ON TRUNC(a.fecha_alquilada) = TRUNC(u.fecha_registro);--Relacionamos las tablas directamente a través de las fechas utilizando TRUNC que pone la fecha a 0 en horas/minutos /segundos.
--Básicamente le estamos pidiendo a la base de datos que nos devuelva la información sólo si ambas fechas coinciden (al ejecutarlo no sale nada porque no existe dicha coincidencia)
